# === Anchor / Solana ===
.anchor/
# Ignore target contents but not the directory itself so negations below work
target/*
# Rust target dirs inside program crates
programs/**/target/
*.so
test-ledger/
.crates.toml
.crates2.json

# IDL and generated TS types must be committed — SDK teammate needs them
!target/idl/
!target/types/

# === Rust ===
**/*.rs.bk
Cargo.lock

# === Node / TypeScript ===
node_modules/
**/node_modules/
dist/
build/
.next/
out/
*.tsbuildinfo
.turbo/

# === Package managers ===
.pnpm-store/
.yarn/
.yarnrc

# === Environment / secrets ===
.env
.env.local
.env.*.local
*.pem
*.key
**/keypair.json
**/*-keypair.json

# === IDE / OS ===
.vscode/
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# === Logs ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# === Misc ===
*.tmp
.cache/
coverage/
**/.wallet.json
